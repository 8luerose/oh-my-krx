# Database
DB_HOST=mysql
DB_PORT=3306
DB_NAME=kr_stock_daily_brief
DB_USER=app
DB_PASSWORD=app
DB_ROOT_PASSWORD=root

# Ports
MYSQL_PORT=3306
BACKEND_PORT=8080
FRONTEND_PORT=5173
MARKETDATA_PORT=8000
AI_SERVICE_PORT=8100
QDRANT_PORT=6333

# Container timezone
TZ=Asia/Seoul

# API
API_BASE_URL=http://localhost:8080

# Market data
MARKETDATA_PROVIDER=pykrx
MARKETDATA_BASE_URL=http://marketdata:8000

# AI/RAG service
AI_SERVICE_BASE_URL=http://ai-service:8100
QDRANT_URL=http://qdrant:6333
QDRANT_ENABLED=true
QDRANT_COLLECTION=kr_stock_ai_memory_ollama
QDRANT_VECTOR_PROVIDER=auto
QDRANT_EMBEDDING_MODEL=auto
QDRANT_EMBEDDING_TIMEOUT_SECONDS=2
QDRANT_VECTOR_SIZE=4096
QDRANT_MAX_DOCUMENTS=16
QDRANT_TIMEOUT_SECONDS=2.5
QDRANT_INSIGHTS_SYNC_ENABLED=false
QDRANT_INSIGHTS_ASYNC_UPSERT_ENABLED=true
LLM_PROVIDER=ollama
# Optional OpenAI-compatible LLM adapter. Leave empty to use safe rule-based fallback.
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=
LLM_API_KEY=
ZAI_API_KEY=
OPENAI_API_KEY=
LLM_TIMEOUT_SECONDS=20
LLM_MAX_TOKENS=650
# Optional local Ollama adapter. Use the Ollama already installed on the host PC.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_PORT=11434
OLLAMA_MODEL=auto
OLLAMA_TIMEOUT_SECONDS=18
OLLAMA_LEARNING_TIMEOUT_SECONDS=4
OLLAMA_JSON_TIMEOUT_SECONDS=6
OLLAMA_STATUS_TIMEOUT_SECONDS=2.5
OLLAMA_NUM_PREDICT=420
OLLAMA_JSON_NUM_PREDICT=80
# Optional Anthropic-compatible LLM adapter.
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=
ANTHROPIC_DEFAULT_SONNET_MODEL=
ANTHROPIC_DEFAULT_OPUS_MODEL=
ANTHROPIC_DEFAULT_HAIKU_MODEL=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_API_KEY=
ANTHROPIC_VERSION=2023-06-01
AI_CLIENT_CONNECT_TIMEOUT_SECONDS=3
AI_CLIENT_READ_TIMEOUT_SECONDS=60
JAVA_TOOL_OPTIONS=

# Optional access gate (leave empty to disable)
PUBLIC_KEY=

# Admin key for protected operations (recommended for production)
ADMIN_KEY=

# Trusted CIDRs for admin bypass (default: localhost only)
# Set to empty string to disable local bypass entirely for production
# Example for Docker: 127.0.0.1/32,::1/128,172.16.0.0/12
APP_ADMIN_TRUSTED_CIDRS=127.0.0.1/32,::1/128

# Discord (Webhook posting)
# To post into a specific thread, set DISCORD_THREAD_ID.
DISCORD_WEBHOOK_URL=
DISCORD_THREAD_ID=

# KRX login credentials (for pykrx >= 1.2.5)
# Sign up for free at https://data.krx.co.kr (KRX Data Portal)
# auto: use KRX_ID/KRX_PW when both are present; otherwise use anonymous browser-like requests.
KRX_AUTH_ENABLED=auto
KRX_ID=
KRX_PW=
