# kr-stock-daily-brief local environment
# Copy this file to .env and put real credentials only in .env.

# Database
DB_HOST=mysql
DB_PORT=3306
DB_NAME=kr_stock_daily_brief
DB_USER=app
DB_PASSWORD=app
DB_ROOT_PASSWORD=root

# Service ports
MYSQL_PORT=3306
BACKEND_PORT=8080
FRONTEND_PORT=5173
MARKETDATA_PORT=8000
AI_SERVICE_PORT=8100
QDRANT_PORT=6333
OLLAMA_PORT=11434

# Runtime routing
TZ=Asia/Seoul
API_BASE_URL=http://localhost:8080
MARKETDATA_PROVIDER=pykrx
MARKETDATA_BASE_URL=http://marketdata:8000
AI_SERVICE_BASE_URL=http://ai-service:8100
AI_CLIENT_CONNECT_TIMEOUT_SECONDS=3
AI_CLIENT_READ_TIMEOUT_SECONDS=60
APP_ADMIN_TRUSTED_CIDRS=127.0.0.1/32,::1/128

# Qdrant/RAG memory
QDRANT_URL=http://qdrant:6333
QDRANT_ENABLED=true
QDRANT_COLLECTION=kr_stock_ai_memory_ollama
QDRANT_VECTOR_PROVIDER=auto
QDRANT_EMBEDDING_MODEL=auto
QDRANT_EMBEDDING_TIMEOUT_SECONDS=2
QDRANT_VECTOR_SIZE=4096
QDRANT_MAX_DOCUMENTS=16
QDRANT_TIMEOUT_SECONDS=2.5
QDRANT_INSIGHTS_SYNC_ENABLED=false
QDRANT_INSIGHTS_ASYNC_UPSERT_ENABLED=true

# Current LLM setup: host Ollama
LLM_PROVIDER=ollama
LLM_TIMEOUT_SECONDS=20
LLM_MAX_TOKENS=650
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=auto
OLLAMA_TIMEOUT_SECONDS=18
OLLAMA_LEARNING_TIMEOUT_SECONDS=4
OLLAMA_JSON_TIMEOUT_SECONDS=6
OLLAMA_STATUS_TIMEOUT_SECONDS=2.5
OLLAMA_NUM_PREDICT=420
OLLAMA_JSON_NUM_PREDICT=80

# KRX credentials
# auto: use KRX_ID/KRX_PW when both are present; otherwise use anonymous requests.
KRX_AUTH_ENABLED=auto
KRX_ID=
KRX_PW=
